;; FiFO SatPlan encoding generated by pddl2fifo
;; Problem pb7 from pb7.pddl
;; Domain logistics-costs from logistics-costs.pddl

;; Time horizon -- numslices is taken from the Lisp variable
;; *satplan-numslices* when it is bound to an integer, else 2.
(alias numslices
 (lisp
  (if (and (boundp '*satplan-numslices*)
           (integerp (symbol-value '*satplan-numslices*)))
      (symbol-value '*satplan-numslices*)
      2)))
(domain slices (range 1 numslices))
(domain actslices (range 1 (- numslices 1)))

;; Objects
(domain objects
 (set pkg1 pkg2 pkg3 t1 t2 t3 p1 p2 p3 l1 l2 l3 a1 a2 a3 c1 c2 c3))

;; Type domains
(domain airplane (set p1 p2 p3))
(domain airport (set a1 a2 a3))
(domain city (set c1 c2 c3))
(domain location (set l1 l2 l3 a1 a2 a3))
(domain package (set pkg1 pkg2 pkg3))
(domain truck (set t1 t2 t3))
(domain vehicle (set t1 t2 t3 p1 p2 p3))

;; Static predicates (never added or deleted): observed,
;; with all positive instances from the initial state.  The
;; dummy facts only register each predicate as observed.
(observed (in-city pddl2fifo-static-dummy pddl2fifo-static-dummy)
 (in-city l1 c1) (in-city a1 c1) (in-city l2 c2) (in-city a2 c2)
 (in-city l3 c3) (in-city a3 c3))

;; Action preconditions, effects, and costs
(observed
 (all obj package true
  (all truck-v truck true
   (all loc location true
    (and (pre (load-truck obj truck-v loc) (at truck-v loc))
         (pre (load-truck obj truck-v loc) (at obj loc))
         (add (load-truck obj truck-v loc) (in obj truck-v))
         (del (load-truck obj truck-v loc) (at obj loc))
         (cost (load-truck obj truck-v loc) 1.0)))))
 (all obj package true
  (all airplane-v airplane true
   (all loc airport true
    (and (pre (load-airplane obj airplane-v loc) (at obj loc))
         (pre (load-airplane obj airplane-v loc) (at airplane-v loc))
         (add (load-airplane obj airplane-v loc) (in obj airplane-v))
         (del (load-airplane obj airplane-v loc) (at obj loc))
         (cost (load-airplane obj airplane-v loc) 1.0)))))
 (all obj package true
  (all truck-v truck true
   (all loc location true
    (and (pre (unload-truck obj truck-v loc) (at truck-v loc))
         (pre (unload-truck obj truck-v loc) (in obj truck-v))
         (add (unload-truck obj truck-v loc) (at obj loc))
         (del (unload-truck obj truck-v loc) (in obj truck-v))
         (cost (unload-truck obj truck-v loc) 1.0)))))
 (all obj package true
  (all airplane-v airplane true
   (all loc airport true
    (and (pre (unload-airplane obj airplane-v loc) (in obj airplane-v))
         (pre (unload-airplane obj airplane-v loc) (at airplane-v loc))
         (add (unload-airplane obj airplane-v loc) (at obj loc))
         (del (unload-airplane obj airplane-v loc) (in obj airplane-v))
         (cost (unload-airplane obj airplane-v loc) 1.0)))))
 (all truck-v truck true
  (all (loc-from loc-to) location true
   (all city-v city true
    (if (and (in-city loc-from city-v) (in-city loc-to city-v))
        (and
         (pre (drive-truck truck-v loc-from loc-to city-v)
          (at truck-v loc-from))
         (add (drive-truck truck-v loc-from loc-to city-v) (at truck-v loc-to))
         (del (drive-truck truck-v loc-from loc-to city-v)
          (at truck-v loc-from))
         (cost (drive-truck truck-v loc-from loc-to city-v) 4.0))))))
 (all airplane-v airplane true
  (all (loc-from loc-to) airport true
   (and
    (pre (fly-airplane airplane-v loc-from loc-to) (at airplane-v loc-from))
    (add (fly-airplane airplane-v loc-from loc-to) (at airplane-v loc-to))
    (del (fly-airplane airplane-v loc-from loc-to) (at airplane-v loc-from))
    (cost (fly-airplane airplane-v loc-from loc-to) 15.0)))))

;; Initial and goal states
(domain initial-state
 (set (at t1 l1) (at t2 l2) (at t3 l3) (at p1 a1) (at p2 a2) (at p3 a3)
      (in pkg1 t1) (in pkg2 t2) (in pkg3 t3)))
(domain goal-state (set (at pkg1 a2) (at pkg2 a3) (at pkg3 a1)))

;; Domains derived from the observed action schemas
(domain actions
 (union (collect a (pre a *))
        (union (collect a (add a *)) (collect a (del a *)))))
(domain fluents
 (union (collect f (pre * f))
        (union (collect f (add * f))
               (union (collect f (del * f)) (union initial-state goal-state)))))
(domain costs (collect c (cost * c)))

(include "../../../lisp/satplan.wff")
