(OR (BUY BANANA) (BUY STEAK) (BUY MILK))
(OR (NOT (BUY SPAM)))
(OR (BUY BREAD))
(WEIGHT (BUY STEAK) 110)
(WEIGHT (NOT (BUY MILK)) 220)
(WEIGHT (NOT (BUY EGGS)) 139)
(OPTION WEIGHTS WCNF)
